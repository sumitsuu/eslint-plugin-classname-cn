{
  "name": "eslint-plugin-classname-cn",
  "version": "0.1.1",
  "description": "ESLint plugin that enforces using a cn() utility for dynamic className values in JSX.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "node -e \"import('node:fs').then(({rmSync}) => rmSync('dist', { recursive: true, force: true }))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "classname",
    "react",
    "jsx",
    "tailwind",
    "cn"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sumitsuu/eslint-plugin-classname-cn.git"
  },
  "bugs": {
    "url": "https://github.com/sumitsuu/eslint-plugin-classname-cn/issues"
  },
  "homepage": "https://github.com/sumitsuu/eslint-plugin-classname-cn#readme",
  "engines": {
    "node": ">=18.18.0"
  },
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
